		"code-review",
		"orchestrator",
		"model-fallback"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kodrunhq/opencode-autopilot.git"
	},
	"homepage": "https://github.com/kodrunhq/opencode-autopilot#readme",
	"bugs": {
		"url": "https://github.com/kodrunhq/opencode-autopilot/issues"
	},
	"engines": {
		"node": ">=22",
		"bun": ">=1.3.11"
	},
	"packageManager": "bun@1.3.11",
	"author": "kodrunhq",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"devDependencies": {
